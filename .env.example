NODE_ENV=production
PORT=3000
SECRET_KEY=petamigos
APP_TIMEZONE=America/Sao_Paulo

# Neon/Postgres
DATABASE_URL=postgresql://USUARIO:SENHA@HOST/DBNAME?sslmode=require

# Optional: Cloudinary for persistent images (recommended on Render)
CLOUDINARY_CLOUD_NAME=
